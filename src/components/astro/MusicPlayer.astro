---
// src/components/astro/MusicPlayer.astro
---
<!-- Floating Music Player -->
<div class="fixed bottom-6 right-6 z-50 select-none">
  <!-- Invisible Audio Tag -->
  <audio id="bg-audio" loop src="/assets/musica/daidai.mp3" preload="auto" autoplay></audio>

  <!-- Floating Controller Trigger -->
  <button 
    id="music-toggle-btn"
    class="w-14 h-14 rounded-full bg-black/60 hover:bg-black/80 border border-[#3CAC3B]/30 hover:border-[#3CAC3B] text-white flex items-center justify-center backdrop-blur-md shadow-[0_0_20px_rgba(60,172,59,0.15)] hover:shadow-[0_0_30px_rgba(60,172,59,0.4)] cursor-pointer group transition-all duration-500 transform hover:scale-105 active:scale-95"
    title="Toggle Background Music"
  >
    <!-- Muted Speaker Icon / Play -->
    <div id="icon-muted" class="flex flex-col items-center justify-center transition-all duration-300">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gray-300 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />
      </svg>
      <span class="text-[8px] font-black text-[#3CAC3B] tracking-wider mt-0.5 animate-pulse uppercase">PLAY</span>
    </div>

    <!-- Active Equalizer Icon / Playing (hidden by default) -->
    <div id="icon-playing" class="hidden items-center justify-center gap-[3px] h-5 w-6 transition-all duration-300">
      <span class="bar bar-1 w-[3px] bg-[#3CAC3B] rounded-full"></span>
      <span class="bar bar-2 w-[3px] bg-[#3CAC3B] rounded-full"></span>
      <span class="bar bar-3 w-[3px] bg-[#3CAC3B] rounded-full"></span>
      <span class="bar bar-4 w-[3px] bg-[#3CAC3B] rounded-full"></span>
    </div>
  </button>
</div>

<style>
  /* Equalizer Animation */
  .bar {
    animation: bounce 0.8s ease-in-out infinite alternate;
  }
  .bar-1 { height: 60%; animation-delay: 0.1s; }
  .bar-2 { height: 100%; animation-delay: 0.3s; }
  .bar-3 { height: 40%; animation-delay: 0.5s; }
  .bar-4 { height: 80%; animation-delay: 0.2s; }

  @keyframes bounce {
    0% { transform: scaleY(0.3); }
    100% { transform: scaleY(1); }
  }
</style>

<script>
  const toggleBtn = document.getElementById('music-toggle-btn');
  const bgAudio = document.getElementById('bg-audio') as HTMLAudioElement;
  const iconMuted = document.getElementById('icon-muted');
  const iconPlaying = document.getElementById('icon-playing');

  // Unified function to successfully play audio and show equalizer
  const startPlaying = () => {
    if (bgAudio && bgAudio.paused) {
      bgAudio.play().then(() => {
        iconMuted?.classList.add('hidden');
        iconPlaying?.classList.remove('hidden');
        iconPlaying?.classList.add('flex');
        toggleBtn?.classList.add('border-[#3CAC3B]', 'shadow-[0_0_25px_rgba(60,172,59,0.5)]');
        
        // Remove document listeners since playback successfully started
        removeGlobalListeners();
      }).catch(err => {
        console.log("Autoplay blocked by browser. Waiting for user interaction...", err);
      });
    }
  };

  // Function to pause audio and reset button
  const stopPlaying = () => {
    if (bgAudio && !bgAudio.paused) {
      bgAudio.pause();
      iconMuted?.classList.remove('hidden');
      iconPlaying?.classList.add('hidden');
      iconPlaying?.classList.remove('flex');
      toggleBtn?.classList.remove('border-[#3CAC3B]', 'shadow-[0_0_25px_rgba(60,172,59,0.5)]');
    }
  };

  // Add click handler to toggle button
  toggleBtn?.addEventListener('click', (e) => {
    e.stopPropagation(); // Avoid triggering body click
    if (bgAudio) {
      if (bgAudio.paused) {
        startPlaying();
      } else {
        stopPlaying();
      }
    }
  });

  // Attempt unmuted autoplay immediately on load (might succeed on some setups)
  window.addEventListener('DOMContentLoaded', () => {
    startPlaying();
    
    // Fallback: Listen for first interaction anywhere on page to trigger unmuted playback
    document.addEventListener('click', startPlaying, { once: true });
    document.addEventListener('touchstart', startPlaying, { once: true });
    document.addEventListener('keydown', startPlaying, { once: true });
  });

  function removeGlobalListeners() {
    document.removeEventListener('click', startPlaying);
    document.removeEventListener('touchstart', startPlaying);
    document.removeEventListener('keydown', startPlaying);
  }
</script>
