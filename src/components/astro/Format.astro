---
// src/components/astro/Format.astro
---
<section class="py-24 bg-[#0a1128] border-y border-white/5 relative overflow-hidden">
  <!-- Glowing circle behind -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-[#3CAC3B]/5 blur-[120px] pointer-events-none rounded-full"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black italic tracking-tighter text-white uppercase mb-4">
        Tournament <span class="text-[#3CAC3B]">Format</span>
      </h2>
      <div class="w-16 h-1 bg-[#3CAC3B] mx-auto transform -skew-x-12"></div>
    </div>

    <!-- Format Details Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- 48-Team Format -->
      <div class="flex flex-col items-center text-center p-8 bg-black/30 border border-white/5 rounded-2xl group hover:border-[#3CAC3B]/30 hover:shadow-[0_0_30px_rgba(60,172,59,0.05)] transition-all duration-500">
        <div class="w-20 h-20 flex items-center justify-center bg-black/60 rounded-2xl border border-[#3CAC3B]/20 text-[#3CAC3B] mb-6 group-hover:bg-[#3CAC3B] group-hover:text-[#050C24] transition-all duration-500 shadow-[0_0_15px_rgba(60,172,59,0.1)] group-hover:shadow-[0_0_25px_rgba(60,172,59,0.4)]">
          <!-- Custom grid icon mirroring the mockup -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <rect x="3" y="3" width="4" height="4" rx="1" />
            <rect x="10" y="3" width="4" height="4" rx="1" />
            <rect x="17" y="3" width="4" height="4" rx="1" />
            <rect x="3" y="10" width="4" height="4" rx="1" />
            <rect x="10" y="10" width="4" height="4" rx="1" />
            <rect x="17" y="10" width="4" height="4" rx="1" />
            <rect x="3" y="17" width="4" height="4" rx="1" />
            <rect x="10" y="17" width="4" height="4" rx="1" />
            <rect x="17" y="17" width="4" height="4" rx="1" />
          </svg>
        </div>
        <h3 class="text-xl font-black italic tracking-tight text-white uppercase mb-3">48-Team Format</h3>
        <p class="text-gray-400 text-sm font-medium leading-relaxed max-w-xs">
          Expanded format, more games, more drama. Experience the largest tournament in history.
        </p>
      </div>

      <!-- 12 Groups of 4 -->
      <div class="flex flex-col items-center text-center p-8 bg-black/30 border border-white/5 rounded-2xl group hover:border-[#3CAC3B]/30 hover:shadow-[0_0_30px_rgba(60,172,59,0.05)] transition-all duration-500">
        <div class="w-20 h-20 flex items-center justify-center bg-black/60 rounded-2xl border border-[#3CAC3B]/20 text-[#3CAC3B] mb-6 group-hover:bg-[#3CAC3B] group-hover:text-[#050C24] transition-all duration-500 shadow-[0_0_15px_rgba(60,172,59,0.1)] group-hover:shadow-[0_0_25px_rgba(60,172,59,0.4)]">
          <!-- Group of 4 dots icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <circle cx="7" cy="7" r="3" />
            <circle cx="17" cy="7" r="3" />
            <circle cx="7" cy="17" r="3" />
            <circle cx="17" cy="17" r="3" />
          </svg>
        </div>
        <h3 class="text-xl font-black italic tracking-tight text-white uppercase mb-3">12 Groups of 4</h3>
        <p class="text-gray-400 text-sm font-medium leading-relaxed max-w-xs">
          Thrilling group stage structure. High stakes matches, intense battle for qualification.
        </p>
      </div>

      <!-- Knockout Stages -->
      <div class="flex flex-col items-center text-center p-8 bg-black/30 border border-white/5 rounded-2xl group hover:border-[#3CAC3B]/30 hover:shadow-[0_0_30px_rgba(60,172,59,0.05)] transition-all duration-500">
        <div class="w-20 h-20 flex items-center justify-center bg-black/60 rounded-2xl border border-[#3CAC3B]/20 text-[#3CAC3B] mb-6 group-hover:bg-[#3CAC3B] group-hover:text-[#050C24] transition-all duration-500 shadow-[0_0_15px_rgba(60,172,59,0.1)] group-hover:shadow-[0_0_25px_rgba(60,172,59,0.4)]">
          <!-- Bracket icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h4v4H4M4 14h4v4H4M8 8h6v8H8M14 12h6" />
          </svg>
        </div>
        <h3 class="text-xl font-black italic tracking-tight text-white uppercase mb-3">Knockout Stages</h3>
        <p class="text-gray-400 text-sm font-medium leading-relaxed max-w-xs">
          Single elimination bracket leading to the final. Every match is win or go home.
        </p>
      </div>
    </div>
  </div>
</section>
