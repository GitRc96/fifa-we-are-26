---
// src/components/astro/Header.astro
---
<header class="fixed w-full top-0 z-50 bg-[#050C24]/85 backdrop-blur-md border-b border-white/5 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="flex-shrink-0 flex items-center">
        <!-- Logo FIFA -->
        <a href="/" class="flex items-center gap-2 group">
          <span class="text-3xl font-black italic tracking-tighter text-white uppercase transition-transform group-hover:scale-105">
            FIFA
          </span>
          <div class="w-1.5 h-6 bg-[#3CAC3B] transform -skew-x-12"></div>
          <span class="text-xs font-bold tracking-widest text-[#3CAC3B] uppercase">WE ARE 26</span>
        </a>
      </div>
      
      <!-- Mockup Menu -->
      <nav class="hidden md:flex items-center space-x-10">
        <a href="#match-center" class="text-gray-300 hover:text-white transition-colors font-bold text-xs uppercase tracking-widest">Live Scores</a>
        <a href="#match-center" class="text-gray-300 hover:text-white transition-colors font-bold text-xs uppercase tracking-widest">Schedule</a>
        <a href="#newsletter" class="text-gray-300 hover:text-white transition-colors font-bold text-xs uppercase tracking-widest">Tickets</a>
      </nav>
      
      <div>
        <a href="#newsletter" class="inline-flex items-center px-6 py-2.5 border-2 border-[#3CAC3B] text-xs font-bold uppercase tracking-widest rounded-full text-[#3CAC3B] hover:text-[#050C24] hover:bg-[#3CAC3B] shadow-[0_0_15px_rgba(60,172,59,0.3)] hover:shadow-[0_0_25px_rgba(60,172,59,0.6)] transition-all duration-300 transform hover:-translate-y-0.5">
          Buy Tickets
        </a>
      </div>
    </div>
  </div>
</header>
