      players: [
        { name: "Alphonso Davies", substitution: "0", shirt_number: "19", photo: "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=120&auto=format&fit=crop&q=80" },
        { name: "Jonathan David", substitution: "0", shirt_number: "9", photo: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&auto=format&fit=crop&q=80" },
        { name: "Stephen Eustáquio", substitution: "0", shirt_number: "7", photo: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=120&auto=format&fit=crop&q=80" },
        { name: "Tajon Buchanan", substitution: "0", shirt_number: "11", photo: "https://images.unsplash.com/photo-1522075469751-3a6694fb2f61?w=120&auto=format&fit=crop&q=80" },
        { name: "Alistair Johnston", substitution: "0", shirt_number: "2", photo: "https://images.unsplash.com/photo-1539571696357-5a69c17a67c6?w=120&auto=format&fit=crop&q=80" },
        { name: "Cyle Larin", substitution: "1", shirt_number: "17", photo: "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?w=120&auto=format&fit=crop&q=80" }
      ]
    }
  };

  // Generate generic fully populated highly polished lineups fallback
  function generateGenericLineup(teamName: string) {
    const commonFirstNames = ["Alexander", "Gabriel", "Lucas", "Matthew", "Daniel", "David", "Thomas", "Michael", "James", "Robert"];
    const commonLastNames = ["Silva", "García", "Smith", "Johnson", "Williams", "Brown", "Jones", "Miller", "Davis", "Rodriguez"];
    const unsplashSportPortraits = [
      "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=120&auto=format&fit=crop&q=80",
      "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&auto=format&fit=crop&q=80",
      "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=120&auto=format&fit=crop&q=80",
      "https://images.unsplash.com/photo-1522075469751-3a6694fb2f61?w=120&auto=format&fit=crop&q=80",
      "https://images.unsplash.com/photo-1539571696357-5a69c17a67c6?w=120&auto=format&fit=crop&q=80",
      "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?w=120&auto=format&fit=crop&q=80",
      "https://images.unsplash.com/photo-1524504388940-b1c1722653e1?w=120&auto=format&fit=crop&q=80",
      "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=120&auto=format&fit=crop&q=80",
      "https://images.unsplash.com/photo-1517841905240-472988babdf9?w=120&auto=format&fit=crop&q=80",
      "https://images.unsplash.com/photo-1508214751196-bcfd4ca60f91?w=120&auto=format&fit=crop&q=80"
    ];

    const players = [];
    // 5 Starters
    for (let i = 1; i <= 5; i++) {
      const name = `${commonFirstNames[Math.floor(Math.random() * commonFirstNames.length)]} ${commonLastNames[Math.floor(Math.random() * commonLastNames.length)]}`;
      players.push({
        name,
        substitution: "0",
        shirt_number: String(Math.floor(Math.random() * 25) + 1),
        photo: unsplashSportPortraits[Math.floor(Math.random() * unsplashSportPortraits.length)]
      });
    }
    // 2 Subs
    for (let i = 1; i <= 2; i++) {
      const name = `${commonFirstNames[Math.floor(Math.random() * commonFirstNames.length)]} ${commonLastNames[Math.floor(Math.random() * commonLastNames.length)]}`;
      players.push({
        name,
        substitution: "1",
        shirt_number: String(Math.floor(Math.random() * 99) + 26),
        photo: unsplashSportPortraits[Math.floor(Math.random() * unsplashSportPortraits.length)]
      });
    }

    return { players };
  }

  // Initial Filter Run on load - Wait for DOM to be ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      filterMatches('GROUP-A');
    });
  } else {
    filterMatches('GROUP-A');
  }

  matchFilterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Toggle button active state
      matchFilterButtons.forEach(b => {
        b.classList.remove('bg-[#3CAC3B]', 'text-[#050C24]', 'border-[#3CAC3B]');
        b.classList.add('border-slate-200', 'text-slate-600');
      });
      btn.classList.add('bg-[#3CAC3B]', 'text-[#050C24]', 'border-[#3CAC3B]');
      btn.classList.remove('border-slate-200', 'text-slate-600');

      const selectedGroup = btn.getAttribute('data-group');
      if (selectedGroup) filterMatches(selectedGroup);
    });
  });

  function filterMatches(group: string) {
    matchCards.forEach(card => {
      const matchGroup = card.getAttribute('data-group');
      
      if (matchGroup === group) {
        card.classList.remove('hidden');
        setTimeout(() => {
          card.classList.remove('scale-95', 'opacity-0');
          card.classList.add('scale-100', 'opacity-100');
        }, 50);
      } else {
        card.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          card.classList.add('hidden');
        }, 200);
      }
    });
  }

  // MODAL LOGIC
  viewStatsButtons.forEach(btn => {
    btn.addEventListener('click', async () => {
      const matchId = btn.getAttribute('data-match-id');
      const team1 = btn.getAttribute('data-team1') || '';
      const team2 = btn.getAttribute('data-team2') || '';
      const team1Logo = btn.getAttribute('data-team1-logo');
      const team1Flag = btn.getAttribute('data-team1-flag') || '⚽';
      const team2Logo = btn.getAttribute('data-team2-logo');
      const team2Flag = btn.getAttribute('data-team2-flag') || '⚽';

      // Set Team details in modal headers
      modalTeam1Name.textContent = team1;
      modalTeam2Name.textContent = team2;

      // Handle logos / flags
      if (team1Logo && team1Logo !== 'null' && team1Logo !== '') {
        modalTeam1Logo.src = team1Logo;
        modalTeam1Logo.classList.remove('hidden');
        modalTeam1Flag.classList.add('hidden');
      } else {
        modalTeam1Flag.textContent = team1Flag;
        modalTeam1Flag.classList.remove('hidden');
        modalTeam1Logo.classList.add('hidden');
      }

      if (team2Logo && team2Logo !== 'null' && team2Logo !== '') {
        modalTeam2Logo.src = team2Logo;
        modalTeam2Logo.classList.remove('hidden');
        modalTeam2Flag.classList.add('hidden');
      } else {
        modalTeam2Flag.textContent = team2Flag;
        modalTeam2Flag.classList.remove('hidden');
        modalTeam2Logo.classList.add('hidden');
      }

      // Show modal & loader
      lineupsModal.classList.remove('hidden');
      setTimeout(() => {
        lineupsModal.classList.remove('opacity-0');
        modalInner.classList.remove('scale-95');
        modalInner.classList.add('scale-100');
      }, 50);

      modalLoader.classList.remove('hidden');
      lineupsContent.classList.add('hidden');

      // Obtener desde las alineaciones precargadas de forma segura en el servidor
      let loadedLineups = null;
      if (matchId && serverLineups[matchId]) {
        loadedLineups = serverLineups[matchId];
      }

      // Fallback if no API response
      if (!loadedLineups) {
        const homeLineup = fallbackLineups[team1] || generateGenericLineup(team1);
        const awayLineup = fallbackLineups[team2] || generateGenericLineup(team2);
        
        loadedLineups = {
          home: { team: { name: team1 }, players: homeLineup.players },
          away: { team: { name: team2 }, players: awayLineup.players }
        };
      }

      // Render players into lists
      renderPlayerLists(loadedLineups.home.players, homeStartersList, homeSubsList);
      renderPlayerLists(loadedLineups.away.players, awayStartersList, awaySubsList);

      // Hide Loader & Show content
      modalLoader.classList.add('hidden');
      lineupsContent.classList.remove('hidden');
    });
  });

  function renderPlayerLists(players: any[], startersList: HTMLDivElement, subsList: HTMLDivElement) {
    startersList.innerHTML = '';
    subsList.innerHTML = '';

    const starters = players.filter(p => p.substitution === "0" || p.substitution === 0);
    const substitutes = players.filter(p => p.substitution === "1" || p.substitution === 1);

    // Starters rendering loop
    starters.forEach(p => {
      const pCard = document.createElement('div');
      pCard.className = 'flex items-center gap-4 p-3 bg-black/30 border border-white/5 rounded-xl group/player hover:border-[#3CAC3B]/30 hover:bg-black/50 transition-all duration-300';
      
      const photoSrc = p.photo || 'https://images.unsplash.com/photo-1508098682722-e99c43a406b2?w=100';
      
      pCard.innerHTML = `
        <div class="relative w-12 h-12 rounded-full border border-white/10 overflow-hidden group-hover/player:border-[#3CAC3B]/50 transition-colors flex-shrink-0">
          <img src="${photoSrc}" alt="${p.name}" class="w-full h-full object-cover transition-transform group-hover/player:scale-105" />
        </div>
        <div class="flex-grow min-w-0 flex justify-between items-center pr-2">
          <span class="font-extrabold italic uppercase tracking-tight text-sm text-white truncate max-w-[170px] group-hover/player:text-[#3CAC3B] transition-colors">${p.name}</span>
          <span class="w-8 h-8 rounded-lg bg-[#3CAC3B]/10 border border-[#3CAC3B]/30 text-[#3CAC3B] flex items-center justify-center text-xs font-black select-none">
            ${p.shirt_number}
          </span>
        </div>
      `;
      startersList.appendChild(pCard);
    });

    // Substitutes rendering loop
    substitutes.forEach(p => {
      const pCard = document.createElement('div');
      pCard.className = 'flex items-center gap-3 p-2 bg-black/20 border border-white/5 rounded-lg group/player hover:border-gray-500/30 hover:bg-black/40 transition-all duration-300';
      
      const photoSrc = p.photo || 'https://images.unsplash.com/photo-1508098682722-e99c43a406b2?w=100';

      pCard.innerHTML = `
        <div class="relative w-9 h-9 rounded-full border border-white/5 overflow-hidden flex-shrink-0">
          <img src="${photoSrc}" alt="${p.name}" class="w-full h-full object-cover" />
        </div>
        <div class="flex-grow min-w-0 flex justify-between items-center pr-2">
          <span class="font-bold uppercase text-xs text-gray-300 truncate max-w-[170px] group-hover/player:text-white transition-colors">${p.name}</span>
          <span class="text-xs font-black text-gray-500 select-none pr-1">#${p.shirt_number}</span>
        </div>
      `;
      subsList.appendChild(pCard);
    });
  }

  // Close modal
  function closeModal() {
    lineupsModal.classList.add('opacity-0');
    modalInner.classList.remove('scale-100');
    modalInner.classList.add('scale-95');
    setTimeout(() => {
      lineupsModal.classList.add('hidden');
    }, 300);
  }

  closeModalBtn?.addEventListener('click', closeModal);
  
  // Close on outer modal click
  lineupsModal?.addEventListener('click', (e) => {
    if (e.target === lineupsModal) closeModal();
  });
  
  // Close on Escape key press
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !lineupsModal.classList.contains('hidden')) closeModal();
  });
</script>

