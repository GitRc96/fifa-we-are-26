---
// src/components/astro/MatchCenter.astro
import { getFixtures, getMatchLineups } from '../../services/worldCupApi';

interface Match {
  id: string | number;
  round: string;
  team1: string;
  team1Logo: string | null;
  team1Flag: string;
  team2: string;
  team2Logo: string | null;
  team2Flag: string;
  time: string;
  date: string;
  group: string;
  location: string;
  odds: {
    home: number;
    away: number;
    draw: number;
  } | null;
}

// Intentar consumir de la API real
let apiData = null;
try {
  apiData = await getFixtures({ lang: 'es' });
} catch (e) {
  console.warn("MatchCenter: Error al conectar con la API de Fixtures. Usando fallback estático.");
}

// Fallback de alta fidelidad basado en el mockup
const mockupMatches: Match[] = [
  { id: 1, round: 'Round 1', team1: 'Mexico', team1Flag: '🇲🇽', team1Logo: 'https://flagcdn.com/w160/mx.png', team2: 'South Africa', team2Flag: '🇿🇦', team2Logo: 'https://flagcdn.com/w160/za.png', time: '00:00', date: '11 JUN', group: 'GROUP-A', location: 'Estadio Azteca, CDMX', odds: { home: 1.85, away: 3.40, draw: 3.10 } },
  { id: 2, round: 'Round 1', team1: 'Canada', team1Flag: '🇨🇦', team1Logo: 'https://flagcdn.com/w160/ca.png', team2: 'Czech Rep.', team2Flag: '🇨🇿', team2Logo: 'https://flagcdn.com/w160/cz.png', time: '00:00', date: '11 JUN', group: 'GROUP-A', location: 'BC Place, Vancouver', odds: { home: 2.10, away: 2.90, draw: 3.20 } },
  { id: 3, round: 'Round 1', team1: 'Colombia', team1Flag: '🇨🇴', team1Logo: 'https://flagcdn.com/w160/co.png', team2: 'Argentina', team2Flag: '🇦🇷', team2Logo: 'https://flagcdn.com/w160/ar.png', time: '00:00', date: '11 JUN', group: 'GROUP-A', location: 'MetLife Stadium, NJ', odds: { home: 3.60, away: 1.70, draw: 3.30 } },
  { id: 4, round: 'Round 1', team1: 'Mexico', team1Flag: '🇲🇽', team1Logo: 'https://flagcdn.com/w160/mx.png', team2: 'USA', team2Flag: '🇺🇸', team2Logo: 'https://flagcdn.com/w160/us.png', time: '00:00', date: '12 JUN', group: 'GROUP-A', location: 'Estadio Azteca, CDMX', odds: { home: 2.30, away: 2.45, draw: 3.00 } },
  { id: 5, round: 'Round 1', team1: 'Argentina', team1Flag: '🇦🇷', team1Logo: 'https://flagcdn.com/w160/ar.png', team2: 'Spain', team2Flag: '🇪🇸', team2Logo: 'https://flagcdn.com/w160/es.png', time: '00:00', date: '12 JUN', group: 'GROUP-B', location: 'Hard Rock Stadium, Miami', odds: { home: 2.20, away: 2.80, draw: 3.15 } },
  { id: 6, round: 'Round 1', team1: 'Czech Rep.', team1Flag: '🇨🇿', team1Logo: 'https://flagcdn.com/w160/cz.png', team2: 'Portugal', team2Flag: '🇵🇹', team2Logo: 'https://flagcdn.com/w160/pt.png', time: '00:00', date: '12 JUN', group: 'GROUP-B', location: 'AT&T Stadium, Dallas', odds: { home: 4.20, away: 1.55, draw: 3.50 } },
  { id: 7, round: 'Round 1', team1: 'Turkey', team1Flag: '🇹🇷', team1Logo: 'https://flagcdn.com/w160/tr.png', team2: 'Argentina', team2Flag: '🇦🇷', team2Logo: 'https://flagcdn.com/w160/ar.png', time: '00:00', date: '13 JUN', group: 'GROUP-B', location: 'SoFi Stadium, LA', odds: { home: 5.00, away: 1.45, draw: 3.80 } },
  { id: 8, round: 'Round 1', team1: 'Czech Rep.', team1Flag: '🇨🇿', team1Logo: 'https://flagcdn.com/w160/cz.png', team2: 'Venezuela', team2Flag: '🇻🇪', team2Logo: 'https://flagcdn.com/w160/ve.png', time: '00:00', date: '13 JUN', group: 'GROUP-C', location: 'Lumen Field, Seattle', odds: { home: 2.40, away: 2.50, draw: 3.10 } },
  { id: 9, round: 'Round 1', team1: 'Turkey', team1Flag: '🇹🇷', team1Logo: 'https://flagcdn.com/w160/tr.png', team2: 'Saudi Arabia', team2Flag: '🇸🇦', team2Logo: 'https://flagcdn.com/w160/sa.png', time: '00:00', date: '13 JUN', group: 'GROUP-C', location: 'Estadio BBVA, Monterrey', odds: { home: 1.95, away: 3.20, draw: 3.30 } }
];

// Si la API devolvió datos válidos estructurados, mapearlos. Si no, usar mockup.
const hasRealData = apiData && Array.isArray(apiData) && apiData.length > 0;
const matches: Match[] = hasRealData 
  ? apiData.map((item: any, index: number): Match => {
      // Formatear fecha YYYY-MM-DD -> DD MMM
      let formattedDate = 'TBD';
      if (item.date) {
        const months = ['JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC', 'JAN', 'FEB', 'MAR', 'APR', 'MAY'];
        const parts = item.date.split('-');
        if (parts.length === 3) {
          const day = parseInt(parts[2], 10);
          const monthIndex = parseInt(parts[1], 10) - 1;
          formattedDate = `${day} ${months[monthIndex] || 'JUN'}`;
        }
      }

      const formattedTime = item.time ? item.time.substring(0, 5) : '00:00';
      const groupLetter = item.group_id ? String.fromCharCode(64 + parseInt(item.group_id, 10)) : 'A';

      return {
        id: item.id || index,
        round: item.round ? `Round ${item.round}` : 'Stage',
        team1: item.home?.name || 'TBD',
        team1Logo: item.home?.logo || null,
        team1Flag: '⚽',
        team2: item.away?.name || 'TBD',
        team2Logo: item.away?.logo || null,
        team2Flag: '⚽',
        time: formattedTime,
        date: formattedDate,
        group: `GROUP-${groupLetter}`,
        location: item.location || 'Stadium',
        odds: item.odds?.pre ? {
          home: parseFloat(item.odds.pre['1']),
          away: parseFloat(item.odds.pre['2']),
          draw: parseFloat(item.odds.pre['X'])
        } : null
      };
    })
  : mockupMatches;

// Pre-fetch de lineups seguro en el servidor (build-time)
const serverLineups: Record<string, any> = {};
if (hasRealData) {
  for (const match of matches) {
    try {
      const data = await getMatchLineups(match.id, 'es');
      if (data && data.home?.players?.length > 0 && data.away?.players?.length > 0) {
        serverLineups[match.id] = data;
      }
    } catch (e) {
      console.warn(`MatchCenter: Error al precargar alineaciones del partido ${match.id}:`, e);
    }
  }
}
---
<section id="match-center" class="py-28 bg-white relative overflow-hidden">
  <!-- Grid decoration background (Light 1.5% opacity grid on white background) -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.015)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.015)_1px,transparent_1px)] bg-[size:40px_40px] pointer-events-none"></div>
  <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-[#3CAC3B]/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black italic tracking-tighter text-slate-900 uppercase mb-4">
        Match <span class="text-[#3CAC3B]">Schedule</span>
      </h2>
      <div class="w-16 h-1 bg-[#3CAC3B] mx-auto mb-10 transform -skew-x-12"></div>
      
      <!-- Group Selectors Tabs -->
      <div class="flex justify-center gap-4">
        <button 
          class="match-filter-btn px-6 py-2 border border-[#3CAC3B] bg-[#3CAC3B] text-[#050C24] text-xs font-black uppercase tracking-widest rounded-md transition-all duration-300 active"
          data-group="GROUP-A"
        >
          Group A
        </button>
        <button 
          class="match-filter-btn px-6 py-2 border border-slate-200 hover:border-[#3CAC3B]/50 text-slate-600 hover:text-[#3CAC3B] text-xs font-black uppercase tracking-widest rounded-md transition-all duration-300"
          data-group="GROUP-B"
        >
          Group B
        </button>
        <button 
          class="match-filter-btn px-6 py-2 border border-slate-200 hover:border-[#3CAC3B]/50 text-slate-600 hover:text-[#3CAC3B] text-xs font-black uppercase tracking-widest rounded-md transition-all duration-300"
          data-group="GROUP-C"
        >
          Group C
        </button>
      </div>
    </div>

    <!-- Match Grid -->
    <div 
      id="match-grid" 
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 transition-all duration-500"
      data-lineups={JSON.stringify(serverLineups)}
    >
      {matches.map((match: Match) => (
        <div 
          class="match-card p-6 bg-slate-50 border border-slate-100 rounded-2xl flex flex-col justify-between group hover:border-[#3CAC3B]/30 hover:shadow-[0_15px_40px_rgba(0,0,0,0.06)] hover:bg-white transition-all duration-500"
          data-group={match.group}
        >
          <!-- Card Header -->
          <div class="flex justify-between items-center text-[10px] font-black tracking-widest text-slate-400 mb-6 uppercase">
            <span>{match.round}</span>
            <span class="text-[#3CAC3B]">{match.date}</span>
          </div>

          <!-- Teams and VS -->
          <div class="flex justify-between items-center mb-6 gap-4">
            <!-- Team 1 -->
            <div class="flex flex-col items-center flex-1 text-center min-w-0">
              {match.team1Logo ? (
                <img src={match.team1Logo} alt={match.team1} class="w-12 h-12 object-contain mb-2 transform group-hover:scale-110 transition-transform duration-500" />
              ) : (
                <span class="text-4xl mb-2 drop-shadow-md transform group-hover:scale-110 transition-transform duration-500">{match.team1Flag}</span>
              )}
              <span class="text-xs font-black italic uppercase tracking-tighter text-slate-900 truncate w-full">{match.team1}</span>
            </div>

            <!-- VS Center -->
            <div class="flex flex-col items-center px-4 py-1.5 bg-slate-100 border border-slate-200/50 rounded-lg select-none min-w-[70px]">
              <span class="text-base font-extrabold italic tracking-tighter text-slate-800">{match.time}</span>
              <span class="text-[8px] font-black text-slate-400 tracking-widest mt-0.5">VS</span>
            </div>

            <!-- Team 2 -->
            <div class="flex flex-col items-center flex-1 text-center min-w-0">
              {match.team2Logo ? (
                <img src={match.team2Logo} alt={match.team2} class="w-12 h-12 object-contain mb-2 transform group-hover:scale-110 transition-transform duration-500" />
              ) : (
                <span class="text-4xl mb-2 drop-shadow-md transform group-hover:scale-110 transition-transform duration-500">{match.team2Flag}</span>
              )}
              <span class="text-xs font-black italic uppercase tracking-tighter text-slate-900 truncate w-full">{match.team2}</span>
            </div>
          </div>
          
          <!-- Location Details -->
          <span class="text-[9px] font-bold text-slate-500 text-center block mb-6 select-none line-clamp-1 group-hover:text-slate-800 transition-colors">
            📍 {match.location}
          </span>

          <!-- Action Buttons -->
          <div class="grid grid-cols-2 gap-3">
            <a 
              href="#" 
              class="flex items-center justify-center px-4 py-2 border-2 border-[#3CAC3B] text-[10px] font-black uppercase tracking-widest text-[#3CAC3B] hover:text-white hover:bg-[#3CAC3B] rounded-lg text-center transition-all duration-300 transform active:scale-95 hover:shadow-[0_5px_15px_rgba(60,172,59,0.3)]"
            >
              Watch Live
            </a>
            <button 
              class="view-stats-btn flex items-center justify-center px-4 py-2 border-2 border-slate-200 hover:border-slate-400 text-[10px] font-black uppercase tracking-widest text-slate-700 hover:bg-slate-100 rounded-lg text-center transition-all duration-300 transform active:scale-95 cursor-pointer"
              data-match-id={match.id}
              data-team1={match.team1}
              data-team2={match.team2}
              data-team1-logo={match.team1Logo}
              data-team1-flag={match.team1Flag}
              data-team2-logo={match.team2Logo}
              data-team2-flag={match.team2Flag}
            >
              View Stats
            </button>
          </div>

          <!-- Betting Odds Footer Overlay (Mockup Premium feature) -->
          {match.odds && (
            <div class="mt-5 pt-4 border-t border-slate-100 flex justify-between text-[10px] font-bold text-slate-400 select-none">
              <span>1: <span class="text-[#3CAC3B] font-extrabold">{match.odds.home.toFixed(2)}</span></span>
              <span>X: <span class="text-slate-800 font-extrabold">{match.odds.draw.toFixed(2)}</span></span>
              <span>2: <span class="text-[#3CAC3B] font-extrabold">{match.odds.away.toFixed(2)}</span></span>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Dynamic Lineups Modal -->
<div id="lineups-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/85 backdrop-blur-md hidden opacity-0 transition-all duration-300">
  <div class="relative w-full max-w-4xl bg-[#0a1128] border border-white/10 rounded-3xl overflow-hidden shadow-[0_0_50px_rgba(0,0,0,0.8)] p-6 sm:p-8 transform scale-95 transition-transform duration-300 flex flex-col max-h-[90vh]">
    <!-- Close button -->
    <button id="close-modal-btn" class="absolute top-6 right-6 text-gray-400 hover:text-white transition-colors cursor-pointer z-55">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Modal Header -->
    <div class="text-center pb-6 border-b border-white/10 select-none">
      <h3 class="text-lg font-black italic tracking-widest text-[#3CAC3B] uppercase mb-1">Match Lineups</h3>
      <div class="flex items-center justify-center gap-6 mt-4">
        <!-- Team 1 header -->
        <div class="flex items-center gap-3">
          <img id="modal-team1-logo" src="" alt="" class="w-10 h-10 object-contain hidden" />
          <span id="modal-team1-flag" class="text-3xl hidden"></span>
          <span id="modal-team1-name" class="text-sm sm:text-lg font-black italic uppercase text-white truncate max-w-[150px]"></span>
        </div>
        <span class="text-xs font-black text-gray-500 tracking-widest">VS</span>
        <!-- Team 2 header -->
        <div class="flex items-center gap-3">
          <span id="modal-team2-name" class="text-sm sm:text-lg font-black italic uppercase text-white truncate max-w-[150px]"></span>
          <img id="modal-team2-logo" src="" alt="" class="w-10 h-10 object-contain hidden" />
          <span id="modal-team2-flag" class="text-3xl hidden"></span>
        </div>
      </div>
    </div>

    <!-- Modal Body (Scrollable container) -->
    <div id="modal-body" class="flex-grow overflow-y-auto py-6 pr-2">
      <!-- Loading Spinner -->
      <div id="modal-loader" class="flex flex-col items-center justify-center py-12">
        <div class="w-12 h-12 border-4 border-[#3CAC3B]/20 border-t-[#3CAC3B] rounded-full animate-spin"></div>
        <span class="text-xs font-black tracking-widest text-[#3CAC3B] uppercase mt-4 animate-pulse">Loading Lineups...</span>
      </div>

      <!-- Lineups Display (columns) -->
      <div id="lineups-content" class="grid grid-cols-1 md:grid-cols-2 gap-8 hidden">
        
        <!-- Home Team lineups -->
        <div class="flex flex-col">
          <div class="flex justify-between items-center mb-4 pb-2 border-b border-white/5">
            <span class="text-xs font-black text-[#3CAC3B] tracking-wider uppercase">Starters</span>
            <span class="text-[10px] text-gray-500 font-bold uppercase">Formation: 4-3-3</span>
          </div>
          <div id="home-starters-list" class="space-y-3"></div>

          <div class="flex justify-between items-center mt-8 mb-4 pb-2 border-b border-white/5">
            <span class="text-xs font-black text-gray-400 tracking-wider uppercase">Substitutes</span>
          </div>
          <div id="home-subs-list" class="space-y-3"></div>
        </div>

        <!-- Away Team lineups -->
        <div class="flex flex-col">
          <div class="flex justify-between items-center mb-4 pb-2 border-b border-white/5">
            <span class="text-xs font-black text-[#3CAC3B] tracking-wider uppercase">Starters</span>
            <span class="text-[10px] text-gray-500 font-bold uppercase">Formation: 4-4-2</span>
          </div>
          <div id="away-starters-list" class="space-y-3"></div>

          <div class="flex justify-between items-center mt-8 mb-4 pb-2 border-b border-white/5">
            <span class="text-xs font-black text-gray-400 tracking-wider uppercase">Substitutes</span>
          </div>
          <div id="away-subs-list" class="space-y-3"></div>
        </div>

      </div>
    </div>
  </div>
</div>

