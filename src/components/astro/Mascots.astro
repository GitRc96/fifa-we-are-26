---
// src/components/astro/Mascots.astro
---
<section id="mascots-section" class="relative h-[80vh] min-h-[550px] w-full overflow-hidden bg-black select-none border-b border-white/5">
  
  <!-- Full Bleed Mascot Background Video (No Dark Overlay, Rich original colors!) -->
  <video 
    id="mascot-section-video" 
    autoplay 
    loop 
    muted 
    playsinline 
    class="absolute inset-0 w-full h-full object-cover opacity-100 scale-100 transition-all duration-700 ease-out z-0"
  >
    <source id="mascot-section-source" src="/assets/videos/zayu-freestayle.mp4" type="video/mp4" />
  </video>

  <!-- Theatrical Flash Overlay for energy burst transition -->
  <div id="mascot-flash-overlay" class="absolute inset-0 bg-white opacity-0 pointer-events-none z-30 transition-opacity duration-300"></div>

  <!-- Content Container -->
  <div class="absolute inset-0 z-10 flex flex-col justify-between p-6 sm:p-12 md:p-16 bg-gradient-to-t from-black/80 via-transparent to-black/35">
    
    <!-- Top Bar: Title & Selectors -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 w-full max-w-7xl mx-auto">
      <div class="text-center md:text-left">
        <span class="text-[10px] font-black tracking-widest text-[#3CAC3B] uppercase">Official Ambassadors</span>
        <h2 class="text-3xl md:text-4xl font-black italic tracking-tighter text-white uppercase mt-1">
          Meet the <span class="text-[#3CAC3B]">Mascots</span>
        </h2>
      </div>

      <!-- Mascot Selector Cards -->
      <div class="flex gap-3 sm:gap-4 bg-black/50 backdrop-blur-md p-1.5 rounded-2xl border border-white/10">
        <button 
          class="mascot-select-btn px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-500 cursor-pointer flex items-center gap-2 active bg-[#3CAC3B] text-[#050C24] shadow-[0_0_15px_rgba(60,172,59,0.4)]"
          data-mascot="MEX"
          data-video="/assets/videos/zayu-freestayle.mp4"
          data-name="Zayu"
          data-tagline="The Mystical Guardian"
          data-bio="Inspired by the agile jaguar and Mexican cultural heritage, Zayu represents speed, mysticism, and the passionate heart of Aztec football history."
          data-color="#3CAC3B"
        >
          🇲🇽 Mexico
        </button>
        <button 
          class="mascot-select-btn px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-500 cursor-pointer flex items-center gap-2 text-white hover:bg-white/10"
          data-mascot="CAN"
          data-video="/assets/videos/maple-freestayle.mp4"
          data-name="Maple"
          data-tagline="The Untamed Energy"
          data-bio="Canada's bold moose ambassador. Maple brings the wild strength of the Great White North, combining competitive power with a warm, welcoming spirit."
          data-color="#E61D25"
        >
          🇨🇦 Canada
        </button>
        <button 
          class="mascot-select-btn px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-500 cursor-pointer flex items-center gap-2 text-white hover:bg-white/10"
          data-mascot="USA"
          data-video="/assets/videos/eeuu-freestayle.mp4"
          data-name="Clutch"
          data-tagline="The Sky Ambition"
          data-bio="Symbolizing the eagle of liberty and flight. Clutch channels absolute focus, fierce ambition, and USA's dream of reaching the ultimate heights."
          data-color="#035AAA"
        >
          🇺🇸 USA
        </button>
      </div>
    </div>

    <!-- Middle Display: Beautiful Centered Glassmorphic Details Card -->
    <div class="flex-grow flex items-center justify-center w-full max-w-4xl mx-auto mt-8 md:mt-14">
      
      <div 
        id="mascot-details-card" 
        class="bg-black/60 backdrop-blur-xl border border-white/10 rounded-3xl p-8 sm:p-10 w-full max-w-xl shadow-[0_20px_50px_rgba(0,0,0,0.5)] text-center transition-all duration-500 transform translate-y-0 scale-100 opacity-100"
      >
        <span id="mascot-tagline" class="text-xs sm:text-sm font-black tracking-widest text-[#3CAC3B] uppercase block mb-2 transition-colors duration-500">
          The Mystical Guardian
        </span>
        <h3 id="mascot-name" class="text-4xl sm:text-5xl md:text-6xl font-black italic tracking-tighter text-white uppercase mb-6 leading-none">
          Zayu
        </h3>
        <p id="mascot-bio" class="text-gray-200 text-sm sm:text-base font-medium leading-relaxed max-w-md mx-auto">
          Inspired by the agile jaguar and Mexican cultural heritage, Zayu represents speed, mysticism, and the passionate heart of Aztec football history.
        </p>
      </div>

    </div>
  </div>
</section>

<script>
  const mascotButtons = document.querySelectorAll('.mascot-select-btn');
  
  // Elements
  const mascotVideo = document.getElementById('mascot-section-video') as HTMLVideoElement;
  const mascotVideoSource = document.getElementById('mascot-section-source') as HTMLSourceElement;
  const flashOverlay = document.getElementById('mascot-flash-overlay') as HTMLDivElement;
  const detailsCard = document.getElementById('mascot-details-card') as HTMLDivElement;
  
  // Details elements
  const mascotTagline = document.getElementById('mascot-tagline') as HTMLSpanElement;
  const mascotName = document.getElementById('mascot-name') as HTMLHeadingElement;
  const mascotBio = document.getElementById('mascot-bio') as HTMLParagraphElement;

  mascotButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Avoid clicking already active mascot
      if (btn.classList.contains('bg-[#3CAC3B]') || btn.classList.contains('bg-[#E61D25]') || btn.classList.contains('bg-[#035AAA]')) {
        return;
      }

      const activeColor = btn.getAttribute('data-color') || '#3CAC3B';
      
      // Reset button classes
      mascotButtons.forEach(b => {
        b.classList.remove(
          'bg-[#3CAC3B]', 'text-[#050C24]', 'shadow-[0_0_15px_rgba(60,172,59,0.4)]',
          'bg-[#E61D25]', 'shadow-[0_0_15px_rgba(230,29,37,0.4)]',
          'bg-[#035AAA]', 'shadow-[0_0_15px_rgba(3,90,170,0.4)]'
        );
        b.classList.add('text-white', 'hover:bg-white/10');
      });

      // Apply new active button styling based on country colors
      btn.classList.remove('text-white', 'hover:bg-white/10');
      if (activeColor === '#3CAC3B') {
        btn.classList.add('bg-[#3CAC3B]', 'text-[#050C24]', 'shadow-[0_0_15px_rgba(60,172,59,0.4)]');
      } else if (activeColor === '#E61D25') {
        btn.classList.add('bg-[#E61D25]', 'text-white', 'shadow-[0_0_15px_rgba(230,29,37,0.4)]');
      } else {
        btn.classList.add('bg-[#035AAA]', 'text-white', 'shadow-[0_0_15px_rgba(3,90,170,0.4)]');
      }

      // Read details from data attributes
      const videoSrc = btn.getAttribute('data-video') || '';
      const name = btn.getAttribute('data-name') || '';
      const tagline = btn.getAttribute('data-tagline') || '';
      const bio = btn.getAttribute('data-bio') || '';

      // --- THEATRICAL TRANSITION ANIMATIONS ---
      
      // 1. Camera Flash Overlay Burst
      if (flashOverlay) {
        flashOverlay.style.opacity = '0.9';
        setTimeout(() => {
          flashOverlay.style.opacity = '0';
        }, 300);
      }

      // 2. Background Video Zoom Out
      if (mascotVideo) {
        mascotVideo.classList.remove('scale-100');
        mascotVideo.classList.add('scale-110', 'opacity-70');
      }

      // 3. Zoom / Translate Down details card
      if (detailsCard) {
        detailsCard.classList.remove('translate-y-0', 'scale-100', 'opacity-100');
        detailsCard.classList.add('translate-y-8', 'scale-95', 'opacity-0');
      }

      // 4. Update data and trigger load in the middle of transition
      setTimeout(() => {
        // Change source and reload video
        if (mascotVideo && mascotVideoSource) {
          mascotVideoSource.src = videoSrc;
          mascotVideo.load();
          mascotVideo.play().catch(err => console.warn(err));
        }

        // Update texts
        if (mascotTagline) {
          mascotTagline.textContent = tagline;
          mascotTagline.style.color = activeColor;
        }
        if (mascotName) mascotName.textContent = name;
        if (mascotBio) mascotBio.textContent = bio;

        // Slide card in from above with bounce
        if (detailsCard) {
          detailsCard.classList.remove('translate-y-8');
          detailsCard.classList.add('-translate-y-8');
        }

        // Final restore animation
        setTimeout(() => {
          if (mascotVideo) {
            mascotVideo.classList.remove('scale-110', 'opacity-70');
            mascotVideo.classList.add('scale-100');
          }
          if (detailsCard) {
            detailsCard.classList.remove('-translate-y-8', 'scale-95', 'opacity-0');
            detailsCard.classList.add('translate-y-0', 'scale-100', 'opacity-100');
          }
        }, 50);

      }, 350);

    });
  });
</script>
