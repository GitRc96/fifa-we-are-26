---
// src/components/astro/BestTalents.astro

const talents = [
  {
    id: 'talent-1',
    name: 'Intro Tour 2026',
    role: 'Official Teaser',
    videoUrl: '/assets/videos/intro.mp4',
    poster: '/assets/images/general/copa.jpg'
  },
  {
    id: 'talent-2',
    name: 'Zayu Freestyle',
    role: 'Skill Master',
    videoUrl: '/assets/videos/zayu-freestayle.mp4',
    poster: '/assets/images/general/stadium.png'
  },
  {
    id: 'talent-3',
    name: 'Maple Skillset',
    role: 'Ball Control',
    videoUrl: '/assets/videos/maple-freestayle.mp4',
    poster: '/assets/images/general/partido.jpg'
  }
];
---
<section id="talents" class="py-28 bg-[#050C24] relative overflow-hidden border-t border-white/5">
  <!-- Glowing effects mimicking phone spotlights -->
  <div class="absolute top-1/4 left-1/3 w-[300px] h-[600px] bg-purple-500/5 rounded-full blur-[120px] pointer-events-none transform -rotate-45"></div>
  <div class="absolute bottom-1/4 right-1/3 w-[300px] h-[600px] bg-cyan-500/5 rounded-full blur-[120px] pointer-events-none transform -rotate-45"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl font-black italic tracking-tighter text-white uppercase mb-4">
        Best <span class="text-[#3CAC3B]">Talents</span>
      </h2>
      <div class="w-16 h-1 bg-[#3CAC3B] mx-auto mb-6 transform -skew-x-12"></div>
      <a href="#" class="inline-block text-[10px] font-black tracking-widest text-[#3CAC3B] hover:text-white uppercase border-b-2 border-[#3CAC3B] hover:border-white pb-1 transition-colors duration-300">
        All Brand Talents
      </a>
    </div>

    <!-- 3 Phone Mockups Container -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 max-w-5xl mx-auto px-4">
      {talents.map((talent) => (
        <div class="flex flex-col items-center">
          <!-- iPhone Shell Mockup (9:16 Ratio) -->
          <div class="relative w-full max-w-[280px] aspect-[9/19] bg-[#020512] rounded-[42px] p-3 shadow-[0_25px_60px_-15px_rgba(0,0,0,0.9),0_0_0_1px_rgba(255,255,255,0.05),0_0_15px_rgba(255,255,255,0.02)] border border-white/10 group hover:shadow-[0_30px_70px_rgba(60,172,59,0.15)] hover:border-[#3CAC3B]/40 transition-all duration-500">
            
            <!-- Dynamic Island Notch -->
            <div class="absolute top-5 left-1/2 -translate-x-1/2 w-28 h-6 bg-black rounded-full z-30 flex items-center justify-center border border-white/5">
              <div class="w-2.5 h-2.5 rounded-full bg-[#111] border border-white/5 mr-6"></div>
              <div class="w-1.5 h-1.5 rounded-full bg-blue-900/40"></div>
            </div>

            <!-- Side Buttons Mockup -->
            <div class="absolute -left-[3px] top-28 w-[3px] h-10 bg-white/20 rounded-l-md"></div>
            <div class="absolute -left-[3px] top-40 w-[3px] h-14 bg-white/20 rounded-l-md"></div>
            <div class="absolute -left-[3px] top-56 w-[3px] h-14 bg-white/20 rounded-l-md"></div>
            <div class="absolute -right-[3px] top-36 w-[3px] h-20 bg-white/20 rounded-r-md"></div>

            <!-- Screen Area -->
            <div class="relative w-full h-full rounded-[32px] overflow-hidden bg-black z-10">
              <video 
                id={talent.id}
                class="talent-video w-full h-full object-cover cursor-pointer"
                loop
                playsinline
                preload="metadata"
                poster={talent.poster}
              >
                <source src={talent.videoUrl} type="video/mp4" />
              </video>

              <!-- Video Controls Overlay -->
              <div class="video-overlay absolute inset-0 bg-black/40 group-hover:bg-black/25 flex flex-col justify-between p-6 transition-colors duration-300 z-20 pointer-events-none">
                <!-- Top Badge -->
                <div class="flex justify-between items-center w-full">
                  <span class="px-2 py-0.5 bg-[#3CAC3B] text-black font-black text-[8px] rounded uppercase tracking-wider">
                    {talent.role}
                  </span>
                  <div class="w-2 h-2 rounded-full bg-[#3CAC3B] animate-pulse"></div>
                </div>

                <!-- Play/Pause Overlay Icon (Center) -->
                <div class="self-center w-14 h-14 rounded-full bg-black/60 border border-white/20 flex items-center justify-center backdrop-blur-md opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-300">
                  <!-- Play Icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="play-icon w-6 h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                  <!-- Pause Icon (hidden by default) -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="pause-icon w-6 h-6 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
                  </svg>
                </div>

                <!-- Details (Bottom) -->
                <div class="w-full text-left">
                  <h4 class="text-white text-base font-black italic tracking-tight uppercase leading-none mb-1">
                    {talent.name}
                  </h4>
                  <p class="text-gray-300 text-[10px] tracking-wider uppercase font-semibold">@FIFAWorldCup2026</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const videos = document.querySelectorAll('.talent-video') as NodeListOf<HTMLVideoElement>;
  const overlays = document.querySelectorAll('.video-overlay');

  videos.forEach((video) => {
    // Add click event to video
    video.addEventListener('click', () => {
      togglePlay(video);
    });

    // Mirror event on click of shell screen overlay (if we had separated pointer-events)
  });

  // Make overlays trigger play as well by adding click handler (since overlay has pointer-events-none, we apply clicks to parent of screen)
  const phoneScreens = document.querySelectorAll('.group');
  phoneScreens.forEach(screen => {
    screen.addEventListener('click', (e) => {
      const video = screen.querySelector('.talent-video') as HTMLVideoElement;
      if (video) togglePlay(video);
    });
  });

  function togglePlay(video: HTMLVideoElement) {
    const parent = video.closest('.group');
    const playIcon = parent?.querySelector('.play-icon');
    const pauseIcon = parent?.querySelector('.pause-icon');
    const overlay = parent?.querySelector('.video-overlay');

    if (video.paused) {
      // Pause all other videos first
      videos.forEach(v => {
        if (v !== video) {
          v.pause();
          const pParent = v.closest('.group');
          pParent?.querySelector('.play-icon')?.classList.remove('hidden');
          pParent?.querySelector('.pause-icon')?.classList.add('hidden');
          pParent?.querySelector('.video-overlay')?.classList.remove('opacity-0');
          pParent?.querySelector('.video-overlay')?.classList.add('bg-black/40');
        }
      });

      // Play this video
      video.play().then(() => {
        playIcon?.classList.add('hidden');
        pauseIcon?.classList.remove('hidden');
        // Hide details overlay during play for full view
        overlay?.classList.add('opacity-0');
        overlay?.classList.remove('bg-black/40');
      }).catch(err => {
        console.error("Error playing video:", err);
      });
    } else {
      // Pause this video
      video.pause();
      playIcon?.classList.remove('hidden');
      pauseIcon?.classList.add('hidden');
      overlay?.classList.remove('opacity-0');
      overlay?.classList.add('bg-black/40');
    }
  }
</script>
